# Nuxt dev/build outputs
.output
.data
.nuxt
.nitro
.cache
dist

# Node dependencies
node_modules

# Logs
logs
*.log

# Misc
.DS_Store
.fleet
.idea

# Local env files
.env
.env.*
!.env.example

# Tauri sidecar binaries — build artifacts produced by `pnpm build:daemon`
# (scripts/build-daemon.js compiles nanna-daemon and copies it here)
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep


# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
# Keep e2e screenshot goldens, ignore local failure diffs
/e2e/__snapshots__/*-diff.png
/e2e/__snapshots__/*-actual.png
