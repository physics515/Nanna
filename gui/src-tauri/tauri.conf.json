{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nanna",
  "version": "0.2.0",
  "identifier": "com.nanna.app",
  "build": {
    "beforeDevCommand": "pnpm build:daemon:debug && pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build:daemon && pnpm generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Nanna"
    },
    "windows": [
      {
        "title": "Nanna",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/nanna-daemon"
    ],
    "resources": []
  }
}
