{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nanna",
  "version": "0.2.2",
  "identifier": "com.nanna.app",
  "build": {
    "beforeDevCommand": "pnpm build:daemon:debug && pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build:daemon && pnpm generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Nanna"
    },
    "windows": [
      {
        "title": "Nanna",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* https: http:; img-src 'self' data: blob: https: http:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; media-src 'self' blob:; worker-src 'self' blob:; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/nanna-daemon"
    ],
    "resources": [],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/physics515/Nanna/master/.updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBNzc0MTdGM0U5QzU2MTgKUldRWVZwdytmMEYzaW9CeHZET3VEOFhYVzNPZDR5dmZJVGk0SnFLRUQ5cm1VMElUcmVsWWcvZ3kK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
